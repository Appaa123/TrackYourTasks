<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackYourTasks.TasksPage"
             BackgroundImageSource="background_theme.jpg">

    <VerticalStackLayout>
        <Label Text="User Data"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <ScrollView>
            <CollectionView x:Name="UserData"
                            ItemsSource="{Binding Tasks}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="Black" StrokeThickness="1" Margin="5" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="{Binding UserCount}" FontAttributes="Bold"/>
                                <Label Text="{Binding UserLabel}" FontSize="Small"/>
                                <Label Text="{Binding UserClickedYes}"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>
