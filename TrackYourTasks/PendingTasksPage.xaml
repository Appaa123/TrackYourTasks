<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackYourTasks.PendingTasksPage"
             Title="Pending Tasks">

    <Grid RowDefinitions="*,Auto">

        <!-- Tasks List -->
        <CollectionView x:Name="TasksCollection" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10" Padding="15">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="Did you complete the task below?"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Yes"
                                        Clicked="OnYesClicked"
                                        CommandParameter="{Binding Id}"
                                        BackgroundColor="Green"
                                        TextColor="White"/>

                                <Button Text="No"
                                        Clicked="OnNoClicked"
                                        CommandParameter="{Binding Id}"
                                        BackgroundColor="Red"
                                        TextColor="White"/>

                                <Button Text="Skip"
                                        Clicked="OnSkipClicked"
                                        CommandParameter="{Binding Id}"
                                        BackgroundColor="Blue"
                                        TextColor="White"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Skip All Button -->
        <Button Grid.Row="1"
                Text="Skip All"
                Clicked="OnSkipAllClicked"
                BackgroundColor="Blue"
                TextColor="White"
                Margin="10"/>

    </Grid>

</ContentPage>