<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TrackYourTasks.DailyTrackerPage"
    Title="Daily Tracker"
    BackgroundImageSource="background_theme.jpg">

    <ContentPage.Content>
        <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="12">
            <!-- Header -->
            <StackLayout Orientation="Horizontal" Spacing="8" HorizontalOptions="FillAndExpand">
                <Button Text="Add" x:Name="AddButton" />
                <Button Text="Complete Selected" x:Name="CompleteSelectedButton" />
                <Button Text="Delete Selected" x:Name="DeleteSelectedButton" />
                <Label Text="Daily Tasks" VerticalOptions="Center" HorizontalOptions="EndAndExpand" />
            </StackLayout>

            <!-- Tasks list -->
            <CollectionView x:Name="TasksCollection" Grid.Row="1" SelectionMode="None" ItemsLayout="VerticalList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.LeftItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem Text="Delete" BackgroundColor="Crimson" Invoked="OnItemDeleteSwipe" />
                                </SwipeItems>
                            </SwipeView.LeftItems>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem Text="Complete" BackgroundColor="ForestGreen" Invoked="OnItemCompleteSwipe" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- Clean tile: only one left selection checkbox and one right completed checkbox -->
                            <Grid Padding="8" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                                <!-- left: selection checkbox -->
                                <CheckBox
                                    Grid.Column="0"
                                    IsChecked="{Binding IsSelected}"
                                    VerticalOptions="Center"
                                    AutomationId="SelectCheckBox" />

                                <!-- center: title/description/meta -->
                                <StackLayout Grid.Column="1" Spacing="4" Margin="8,0" VerticalOptions="Center">
                                    <Label
                                        Text="{Binding Title, TargetNullValue='(no title)'}"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        TextColor="{StaticResource PrimaryDarkText}" />

                                    <Label
                                        Text="{Binding Description, TargetNullValue=''}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                        LineBreakMode="TailTruncation" />

                                    <StackLayout Orientation="Horizontal" Spacing="12">
                                        <Label Text="{Binding CreatedAtLabel}" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray300}}" />
                                        <Label Text="{Binding RecurrenceLabel}" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray300}}"
                                               IsVisible="{Binding RecurrenceTime, Converter={StaticResource NullToBoolConverter}}" />
                                    </StackLayout>
                                </StackLayout>

                                <!-- right: single completed checkbox -->
                                <CheckBox
                                    Grid.Column="2"
                                    IsChecked="{Binding IsCompleted}"
                                    VerticalOptions="Center"
                                    CheckedChanged="OnItemCompletedChanged"
                                    AutomationId="CompletedCheckBox" />
                            </Grid>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Footer helper -->
            <Label Grid.Row="2" x:Name="EmptyLabel" Text="No daily tasks found." HorizontalOptions="Center" IsVisible="False" />
        </Grid>
    </ContentPage.Content>
</ContentPage>