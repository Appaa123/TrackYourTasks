<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TrackYourTasks"
    x:Class="TrackYourTasks.ViewTasks"
    BackgroundImageSource="background_theme.jpg">

    <!-- Converter -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Layout -->
    <Grid RowDefinitions="*,Auto" Padding="20">

        <!-- TASK LIST -->
        <CollectionView x:Name="TasksList"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <!-- Swipe RIGHT → DELETE -->
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           Invoked="OnDeleteTaskClicked" />
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <!-- TASK CARD -->
                        <Border Stroke="LightGray"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="1"
                                Background="PapayaWhip"
                                Margin="10">

                            <VerticalStackLayout Padding="12" Spacing="8">

                                <!-- Title + Completed + Menu -->
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      VerticalOptions="Center">

                                    <!-- Title -->
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center" />

                                    <!-- Completed Tag -->
                                    <Label Grid.Column="1"
                                           Text="Completed"
                                           TextColor="White"
                                           BackgroundColor="Green"
                                           Padding="6,2"
                                           FontSize="11"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding IsCompleted}" />

                                    <!-- 3 DOT MENU (FIXED) -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="#EEEEEE"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="6"
                                            Margin="5,0,0,0">

                                        <Label Text="⋮"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnMoreClicked"/>
                                        </Border.GestureRecognizers>

                                    </Border>

                                </Grid>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#555"
                                       LineBreakMode="WordWrap" />

                                <!-- Date -->
                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                                       FontSize="12"
                                       TextColor="Gray"
                                       HorizontalOptions="End" />

                            </VerticalStackLayout>

                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- BACK BUTTON -->
        <Button Text="Back"
                Grid.Row="1"
                BackgroundColor="#FFB038"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"
                Clicked="OnBackTaskClicked"
                Margin="0,10,0,0"/>

    </Grid>

</ContentPage>